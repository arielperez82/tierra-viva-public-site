---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_TITLE } from "../consts";
import Link from "../components/Link.astro";
import ramonPhoto from "../assets/ramon-marmolejos.png";
import ranjanPhoto from "../assets/ranjan-khan-profile.jpg";
---

<BaseLayout
  title={`Team & Governance | ${SITE_TITLE}`}
  description="Tierra Viva leadership: Managing Partner, Directors, Investment Committee, and key development partner."
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-24">
    <h1 class="text-2xl tracking-tight sm:text-3xl">
      Team &amp; Governance
    </h1>
    <p class="mt-6 text-base leading-relaxed text-tierra-graphite/90">
      Experienced leadership and structured governance support Tierra Viva's
      platform. The team brings decades of experience across capital markets,
      development, operations, and governance.
    </p>

    <h2 class="mt-10 text-xl font-semibold tracking-tight">
      Managing Partner &amp; Directors
    </h2>
    <div class="mt-6 space-y-8">
      <section class="flex flex-col items-start gap-6 sm:flex-row">
        <div class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-full border-2 border-tierra-stone/40">
          <Image
            src={ramonPhoto}
            alt="Ramon Marmolejos"
            width={96}
            height={96}
            class="h-full w-full object-cover object-top"
          />
        </div>
        <div>
        <h3 class="font-semibold text-tierra-forest-dark">
          Ramon Marmolejos — Managing Partner
        </h3>
        <p class="mt-2 text-base leading-relaxed text-tierra-graphite/90">
          Born in the Dominican Republic, educated in the U.S. and Europe
          (Wharton, IE Business School). Over 20 years leading transformational
          initiatives across business, education, and impact. Co-founder of
          Alkimia Learning; expertise in aligning diverse teams, building
          stakeholder trust, and navigating complex systems. Brings authentic
          narrative and long-term impact focus to each development phase.
        </p>
        </div>
      </section>

      <section class="flex flex-col items-start gap-6 sm:flex-row">
        <div class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-full border-2 border-tierra-stone/40">
          <Image
            src={ranjanPhoto}
            alt="Ranjan Khan"
            width={96}
            height={96}
            class="h-full w-full object-cover object-top"
          />
        </div>
        <div>
        <h3 class="font-semibold text-tierra-forest-dark">
          Ranjan Khan — Managing Director, Investment Committee
        </h3>
        <p class="mt-2 text-base leading-relaxed text-tierra-graphite/90">
          Penn Computer Science graduate with two decades delivering
          cross-functional programs in highly regulated environments. Former
          Director at Dun &amp; Bradstreet's Office of the CTO; led Volcker Rule
          reporting, global supervisory controls, and large-scale client
          onboarding at Credit Suisse and Morgan Stanley. Additional experience
          at Goldman Sachs, eGain, and IBM spanning operations, technology, and
          client outcomes. Leads business strategy, capital investments, and
          portfolio growth—bridging finance, operations, and technology for
          integrated execution.
        </p>
        </div>
      </section>
    </div>

    <p class="mt-10">
      <Link
        href="/"
        class="font-medium text-tierra-forest underline decoration-tierra-stone underline-offset-4 hover:decoration-tierra-forest focus:outline-none focus:ring-2 focus:ring-tierra-lime focus:ring-offset-2"
      >
        Back to home
      </Link>
    </p>
  </article>
</BaseLayout>
